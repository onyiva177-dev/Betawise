{
  "framework": "nextjs",
  "buildCommand": "next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "regions": ["fra1"],
  "headers": [
    {
      "source": "/api/payments/mpesa/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache" },
        { "key": "X-Robots-Tag",  "value": "noindex" }
      ]
    }
  ],
  "rewrites": [],
  "redirects": [
    {
      "source": "/login",
      "destination": "/auth/login",
      "permanent": true
    },
    {
      "source": "/register",
      "destination": "/auth/register",
      "permanent": true
    }
  ]
}
